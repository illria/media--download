# 可留空；首次启动会自动生成 Cookie 加密密钥并保存到 data-v2/database
COOKIE_ENCRYPTION_KEY=

# 可留空，也可以启动后在网页设置中填写并加密保存
SILICONFLOW_API_KEY=

# Koofr 可选配置：未挂载时保持默认即可，镜像和容器仍可正常运行。
# 宿主机实际挂载路径；Compose 会在路径不存在时创建空目录，不会阻止构建。
KOOFR_HOST_PATH=/mnt/koofr
# 容器内挂载目标及项目云盘目录。通常不需要修改。
KOOFR_CONTAINER_PATH=/mnt/koofr
KOOFR_SUBPATH=Media-Download
KOOFR_ROOT=/mnt/koofr/Media-Download
